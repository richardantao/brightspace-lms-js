{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": false,
		"useIgnoreFile": false
	},
	"files": {
		"includes": [
			"src/**",
			"*.json",
			"*.ts",
			"!!**/dist",
			"!!**/node_modules"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"correctness": {
				"recommended": true,
				"noUnusedVariables": "error",
				"useExhaustiveDependencies": "warn"
			},
			"suspicious": {
				"recommended": true,
				"noExplicitAny": "warn",
				"noArrayIndexKey": "warn",
				"useIterableCallbackReturn": "off"
			},
			"style": {
				"preset": "recommended"
			},
			"complexity": {
				"preset": "recommended"
			},
			"performance": {
				"preset": "recommended"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"quoteProperties": "asNeeded",
			"trailingCommas": "es5",
			"semicolons": "always",
			"arrowParentheses": "asNeeded",
			"bracketSpacing": true,
			"bracketSameLine": false
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "off"
			}
		}
	}
}
